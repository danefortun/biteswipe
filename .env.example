FLASK_APP=main
FLASK_DEBUG=false
SECRET_KEY=replace-me-with-a-long-random-value
DATABASE_URL=sqlite:///instance/users.db
POSTS_DATABASE_URL=sqlite:///instance/blogPosts.db
DATABASE_POOL_RECYCLE_SECONDS=1800
UPLOAD_STORAGE_PROVIDER=local
UPLOADS_PUBLIC_BASE_URL=
UPLOADS_S3_BUCKET=
UPLOADS_S3_PREFIX=profile-uploads
GOOGLE_PLACES_API_KEY=
RESTAURANT_PROVIDER=auto
AUTO_CREATE_DB=true
MAX_CONTENT_LENGTH=2097152
RESTAURANT_SEARCH_RADIUS_METERS=2000
OSM_OVERPASS_URL=https://overpass-api.de/api/interpreter
OSM_OVERPASS_TIMEOUT=12
OSM_MAX_RESULTS=25
